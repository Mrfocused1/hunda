{
    "name": "1hundred-ecommerce",
    "version": "1.0.0",
    "description": "1 HUNDRED - Premium Streetwear E-commerce",
    "scripts": {
        "dev": "npx serve . -p 3000",
        "test:screenshots": "node scripts/screenshot-test.js",
        "test:screenshots:mobile": "node scripts/screenshot-test.js --mobile",
        "test:screenshots:desktop": "node scripts/screenshot-test.js --desktop",
        "test:compare": "node scripts/compare-screenshots.js",
        "lint": "stylelint '**/*.css'",
        "lint:fix": "stylelint '**/*.css' --fix",
        "format": "prettier --write '**/*.{html,css,js,json}'",
        "prepare": "husky",
        "screenshot": "node scripts/screenshot-capture.js",
        "screenshot:view": "node scripts/screenshot-capture.js list"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "pixelmatch": "^5.3.0",
        "pngjs": "^7.0.0",
        "prettier": "^3.8.1",
        "puppeteer": "^24.40.0",
        "stylelint": "^17.5.0",
        "stylelint-config-standard": "^40.0.0"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.100.1",
        "pg": "^8.20.0"
    }
}
